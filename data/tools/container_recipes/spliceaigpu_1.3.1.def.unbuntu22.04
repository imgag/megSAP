# Attention:
# we need to use the Ubuntu 22.04 base image from Nvidia, because tensorflow does only support Cuda 12.5 - see https://www.tensorflow.org/install/source
# Ubuntu 22.04 has Python 3.10 and Tensorflow 2.20
# Building the apptainer has to be done on Ubuntu 22.04 because on 24.04 or higher the fakeroot command is built with the wrong GCC version. You can easily build it using WSL.

Bootstrap: docker
From: nvidia/cuda:12.5.1-runtime-ubuntu22.04

%environment
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
	export PATH=/opt/spliceai-venv/bin:$PATH

%post
    # install python/pip
    apt-get update
	apt-get install -y --no-install-recommends software-properties-common wget curl git build-essential ca-certificates unzip python3.10 python3.10-venv python3.10-dev python3-pip
	rm -rf /var/lib/apt/lists/*
	
	# create virtual environment
    python3 -m venv /opt/spliceai-venv
	
	# Activate venv for the rest of the post
    export PATH=/opt/spliceai-venv/bin:$PATH
	
	# Upgrade pip inside venv3
    python3 -m ensurepip --upgrade
	python3 -m pip install --upgrade pip setuptools==68.0.0 wheel
	
	# Install tensorflow
	python3 -m pip install tensorflow==2.20.*
	
    # Install SpliceAI
    python3 -m pip install git+https://github.com/geertvandeweyer/SpliceAI.git
